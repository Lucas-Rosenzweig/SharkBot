// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id           String        @id // Discord Guild ID
  name         String?
  users        User[]
  reactionMaps ReactionMap[]
  levelRoles   LevelRole[]

  config Config?
}

model Config {
  id      Int    @id @default(autoincrement())
  guildId String @unique

  xpCooldown            Int     @default(20) // in seconds
  xpPerMessage          Int     @default(15)
  xpPerMinute           Int     @default(5)
  xpChannelId           String? // ID of the channel where XP messages are sent
  voiceXpRequireUnmuted Boolean @default(false) // If true, muted/deafened users don't earn voice XP
  levelUpMessage        String? // Custom level-up message template (null = default, "" = disabled)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model User {
  id        Int    @id @default(autoincrement())
  guildId   String
  discordId String

  username   String? // Cached Discord username (updated on each XP event)
  avatarHash String? // Cached Discord avatar hash

  xpTotal   Int @default(0)
  xpCurrent Int @default(0)
  xpNext    Int @default(155)
  level     Int @default(1)

  lastMessage DateTime? // Timestamp of the last message sent by the user

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, discordId])
  @@index([guildId, xpTotal(sort: Desc)]) // Leaderboard query: WHERE guildId ORDER BY xpTotal DESC
}

model ReactionMap {
  id              String  @id @default(cuid())
  guildId         String
  messageId       String
  emoji           String
  roleId          String
  removeOnUnreact Boolean @default(false) // Whether to remove the role when the user unreacts

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji])
  @@index([guildId]) // Filter by guild queries
}

model LevelRole {
  id       String @id @default(cuid())
  guildId  String
  roleId   String
  levelReq Int

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, levelReq])
  @@index([guildId]) // Filter by guild queries
}
