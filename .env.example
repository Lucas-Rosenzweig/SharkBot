# ============================================================
# Shark-Bot — Variables d'environnement
# ============================================================
# Copiez ce fichier : cp .env.example .env
# Puis remplissez les valeurs ci-dessous.
# ============================================================

# ── Discord Bot ──────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Discord OAuth2 (https://discord.com/developers/applications) ──
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# ── Database (PostgreSQL) ────────────────────────────────────
# Ces variables sont utilisées par docker-compose pour créer la DB
# et par le bot pour s'y connecter.
POSTGRES_USER=shark
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=sharkbot
# DATABASE_URL est construit automatiquement dans docker-compose.yml
# Si vous lancez le bot hors Docker, décommentez la ligne ci-dessous :
# DATABASE_URL=postgresql://shark:change-me@localhost:5432/sharkbot?schema=public

# ── Session ──────────────────────────────────────────────────
# Générez une clé aléatoire : openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# ── URLs ─────────────────────────────────────────────────────
# DEV  : http://localhost:3001 / http://localhost:3000
# PROD : https://your-domain.com (Coolify gère le HTTPS)
API_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000

# ── Guild (dev only) ────────────────────────────────────────
# GUILD_ID=your_test_guild_id
