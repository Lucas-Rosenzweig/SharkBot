# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here

# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Database
DATABASE_URL=postgresql://bot:bot@db:5432/discordbot?schema=public

# Session secret (generate a random string)
SESSION_SECRET=change-me-to-a-random-secret

# API URL (used for OAuth2 callback)
# Dev:  http://localhost:3001
# Prod: https://your-domain.com or http://bot:3001 (internal)
API_URL=http://localhost:3001

# Dashboard URL (used for OAuth2 redirect after login)
# Dev:  http://localhost:5173
# Prod: https://your-domain.com
DASHBOARD_URL=http://localhost:5173

