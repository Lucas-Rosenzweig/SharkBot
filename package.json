{
  "name": "shark-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --watch src --exec tsx src/index.ts",
    "deploy": "tsx src/scripts/deploy-commands.ts",
    "deploy:guild": "tsx src/scripts/deploy-guild.ts",
    "deploy:global": "tsx src/scripts/deploy-global.ts",
    "purge:guild": "tsx src/scripts/purge-guild.ts",
    "purge:global": "tsx src/scripts/purge-global.ts",
    "purge:all": "tsx src/scripts/purge-guild.ts && tsx src/scripts/purge-global.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "prisma:gen": "prisma generate",
    "prisma:push": "prisma db push",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod down",
    "audit": "pnpm audit",
    "test": "SESSION_SECRET=test-secret-min-32-characters-long DISCORD_CLIENT_ID=test DISCORD_CLIENT_SECRET=test vitest run",
    "test:watch": "SESSION_SECRET=test-secret-min-32-characters-long DISCORD_CLIENT_ID=test DISCORD_CLIENT_SECRET=test vitest",
    "test:security": "SESSION_SECRET=test-secret-min-32-characters-long DISCORD_CLIENT_ID=test DISCORD_CLIENT_SECRET=test vitest run tests/security/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.0",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "@prisma/client": "^6.17.1",
    "@resvg/resvg-js": "^2.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "discord.js": "^14.23.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "prisma": "^6.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.7.2",
    "@types/passport": "^1.0.17",
    "@types/passport-discord": "^0.1.15",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}